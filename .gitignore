# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
__pycache__/
.claude/worktrees/
.env*.local
services/chemistry/cache-sync.env
services/chemistry/*.log
.auth/

# Generated chemistry seed imports and queue outputs.
/data/chemical-seeds/external/*
!/data/chemical-seeds/external/.gitkeep
/data/chemical-seeds/*.generated.json
/data/chemical-seeds/*worker-state*.json
/data/chemical-seeds/backups/
